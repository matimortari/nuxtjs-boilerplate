{
  "name": "nuxtjs-boilerplate",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "start": "node .output/server/index.mjs",
    "postinstall": "nuxt prepare",
    "lint": "eslint . --debug",
    "lint:fix": "eslint . --debug --fix",
    "db:push": "prisma db push",
    "db:dev": "prisma migrate dev",
    "db:deploy": "dotenv -e .env.production prisma migrate deploy",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@nuxt/icon": "1.13.0",
    "@nuxtjs/google-fonts": "3.2.0",
    "@nuxtjs/i18n": "9.5.4",
    "@nuxtjs/supabase": "1.5.1",
    "@nuxtjs/tailwindcss": "6.14.0",
    "@pinia/nuxt": "0.11.0",
    "@prisma/client": "6.8.2",
    "nuxt": "3.17.4"
  },
  "devDependencies": {
    "@hyoban/eslint-plugin-tailwindcss": "4.0.0-alpha.12",
    "@nuxt/devtools": "2.4.1",
    "@nuxt/eslint": "1.4.1",
    "@stylistic/eslint-plugin": "4.4.0",
    "@types/node": "22.15.21",
    "@typescript-eslint/parser": "8.32.1",
    "dotenv-cli": "8.0.0",
    "eslint": "9.27.0",
    "prisma": "6.8.2",
    "typescript": "5.8.3"
  }
}
